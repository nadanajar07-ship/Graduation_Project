          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/notifications", "host": ["{{baseUrl}}"], "path": ["notifications"] }
          }
        }
      ]
    },
    {
      "name": "5. Calls (REST)",
      "item": [
        {
          "name": "GET call history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "rooms", "{{roomId}}", "calls"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET active call",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.data?.call?._id) {",
                  "  pm.environment.set('callId', j.data.call._id);",
                  "  console.log('Saved active callId', j.data.call._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls/active", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "calls", "active"] }
          }
        },
        {
          "name": "GET call detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls/{{callId}}", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "calls", "{{callId}}"] }
          }
        },
        {
          "name": "POST LiveKit join token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('returns token + url', () => {",
                  "  pm.expect(j.data.token).to.be.a('string').and.have.length.greaterThan(50);",
                  "  pm.expect(j.data.url).to.match(/^wss?:\\/\\//);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls/{{callId}}/livekit-token", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "calls", "{{callId}}", "livekit-token"] },
            "body": { "mode": "raw", "raw": "{\n  \"deviceId\": \"postman-desktop-1\"\n}" }
          }
        },
        {
          "name": "POST start recording",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls/{{callId}}/recording", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "calls", "{{callId}}", "recording"] }
          }
        },
        {
          "name": "DELETE stop recording",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls/{{callId}}/recording", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "calls", "{{callId}}", "recording"] }
          }
        },
        {
          "name": "GET recording download URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/calls/{{callId}}/recording/download", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "calls", "{{callId}}", "recording", "download"] }
          }
        }
      ]
    }
  ]
}
