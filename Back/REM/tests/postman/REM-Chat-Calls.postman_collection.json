            ],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/reactions", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "reactions"] },
            "body": { "mode": "raw", "raw": "{\n  \"reaction\": \"👍\"\n}" }
          }
        },
        {
          "name": "DELETE reaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/reactions", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "reactions"] }
          }
        },
        {
          "name": "POST reply (creates thread)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"replying in thread\",\n  \"replyTo\": \"{{messageId}}\"\n}"
            }
          }
        },
        {
          "name": "GET thread",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/thread", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "thread"] }
          }
        },
        {
          "name": "POST pin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/pin", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "pin"] }
          }
        },
        {
          "name": "DELETE unpin",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/pin", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "pin"] }
          }
        },
        {
          "name": "GET pinned",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/pinned", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "pinned"] }
          }
        },
        {
          "name": "POST save (bookmark)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/save", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "save"] },
            "body": { "mode": "raw", "raw": "{\n  \"note\": \"keep for later\"\n}" }
          }
        },
        {
          "name": "DELETE unsave",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/chat/rooms/{{roomId}}/messages/{{messageId}}/save", "host": ["{{baseUrl}}"], "path": ["chat", "rooms", "{{roomId}}", "messages", "{{messageId}}", "save"] }
          }
        },
        {
          "name": "GET /me/saved-messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/me/saved-messages", "host": ["{{baseUrl}}"], "path": ["me", "saved-messages"] }
          }
        },
        {
          "name": "GET /me/mentions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/me/mentions", "host": ["{{baseUrl}}"], "path": ["me", "mentions"] }
          }
