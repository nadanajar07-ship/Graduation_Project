# ─── Environment ───────────────────────────────────────────
# Block every env variant anywhere in the tree, but allow templates.
.env
.env.*
**/.env
**/.env.*
!**/.env.example
!.env.example

# ─── Secrets, keys, credentials ────────────────────────────
# Defensive catch-all in case someone drops creds into the tree.
# NOTE: only ignore a top-level runtime `secrets/` folder — do NOT swallow
# the source module at src/utils/secrets/ (it holds loader logic, no values).
/secrets/
!src/utils/secrets/
!src/utils/secrets/**
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*credentials*.json
service-account*.json
!**/credentials.example.json

# ─── Node ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Logs ──────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ─── Build outputs ─────────────────────────────────────────
dist/
build/

# ─── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Uploads (keep folder, ignore contents) ────────────────
src/uploads/*
!src/uploads/.gitkeep

# ─── Test coverage ─────────────────────────────────────────
coverage/
.nyc_output/

# ─── Caches ────────────────────────────────────────────────
.cache/
tmp/
.tmp/

# ─── Python (for AI services) ──────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ─── Docker (Phase 2) ──────────────────────────────────────
docker/data/
*.docker.env

# ─── Misc ──────────────────────────────────────────────────
*.bak
.eslintcache
node_modules
node_modules
FE/
FE_Angular/
.claude/FE/
FE_Angular/
ai-services/
.claude/
src/uploads/*
!src/uploads/.gitkeep