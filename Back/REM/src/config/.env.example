# ════════════════════════════════════════════════════════════
# REM Backend — Environment Configuration
# Copy to .env.dev (development) or .env.prod (production)
# ════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────
MOOD=DEV
APP_NAME=REM
PORT=3000

# ─── Database ───────────────────────────────────────────────
DB_URI=mongodb+srv://rem_project:<6iLaRFWJp11kYScx>@rem.jwhw8a3.mongodb.net/?appName=REM

# ─── Redis (required from Phase 2 onward) ───────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ───────────────────────────────────────────────
# IMPORTANT: each secret must be at least 32 chars, ideally 64.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SALT=12
USER_ACCESS_TOKEN=REPLACE_WITH_64_CHAR_HEX
USER_REFRESH_TOKEN=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
ADMIN_ACCESS_TOKEN=REPLACE_WITH_64_CHAR_HEX
ADMIN_REFRESH_TOKEN=REPLACE_WITH_DIFFERENT_64_CHAR_HEX
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# ─── Email (SMTP / Gmail App Password) ──────────────────────
EMAIL=your-app@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# ─── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── AI Services (optional) ─────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── LiveKit (Voice/Video SFU) ──────────────────────────────
# Required if call features are enabled. Provision a project on
# https://cloud.livekit.io (or self-hosted) and paste credentials
# into your LOCAL .env.dev / .env.prod — NEVER commit real values.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Optional: override how long room JWTs stay valid (default 4h).
LIVEKIT_TOKEN_TTL=4h
# Optional: shared secret for webhook signature verification
# (LiveKit signs webhooks with LIVEKIT_API_KEY/SECRET by default,
# so leaving this blank is fine for managed cloud setups).
LIVEKIT_WEBHOOK_PATH=/calls/livekit/webhook

# ─── Frontend ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════
# SECRETS POLICY
# ────────────────────────────────────────────────────────────
# • This file (.env.example) is the ONLY env file tracked in git.
# • Never paste real values here. Use placeholder/empty strings.
# • Real credentials live in .env.dev / .env.prod which are
#   excluded by .gitignore.
# • If a real secret ever lands in a commit, rotate immediately
#   AND scrub git history (git filter-repo or BFG).
# ════════════════════════════════════════════════════════════